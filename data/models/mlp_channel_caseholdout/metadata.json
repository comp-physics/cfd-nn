{
  "name": "mlp_mcconkey",
  "type": "nn_mlp",
  "description": "MLP for scalar eddy viscosity trained on McConkey dataset",
  "architecture": {
    "layers": [
      6,
      32,
      32,
      1
    ],
    "activations": [
      "tanh",
      "tanh",
      "relu"
    ],
    "total_parameters": 1313
  },
  "features": {
    "type": "scalar_nut_v1",
    "inputs": [
      "S_mag_delta_over_uref",
      "Omega_mag_delta_over_uref",
      "y_wall_over_delta",
      "Omega_over_S",
      "Re_S_local",
      "u_mag_over_uref"
    ],
    "descriptions": [
      "Normalized strain rate magnitude: |S| * delta / u_ref",
      "Normalized rotation rate magnitude: |Omega| * delta / u_ref",
      "Normalized wall distance: y_wall / delta",
      "Strain-rotation ratio: |Omega| / |S| (0 when |S| < 1e-10)",
      "Local strain Reynolds number: |S| * delta^2 / nu",
      "Normalized velocity magnitude: |u| / u_ref"
    ],
    "normalization": "z-score",
    "notes": "k and omega are accepted by the API but currently unused (reserved for future extension)"
  },
  "dataset": {
    "source": "McConkey et al. (2021)",
    "doi": "10.1038/s41597-021-01034-2"
  },
  "usage": {
    "command": "./channel --model nn_mlp --nn_preset mlp_mcconkey"
  }
}